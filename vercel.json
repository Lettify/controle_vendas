{
  "buildCommand": "npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/trpc/:trpc*",
      "destination": "/api/trpc/[trpc]"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/trpc/[trpc].ts": {
      "maxDuration": 10
    }
  },
  "regions": ["gru1"]
}